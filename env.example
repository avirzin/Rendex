# ── Deployer wallet ───────────────────────────────────────────────────────────
# Private key of the wallet that will deploy the contracts (no 0x prefix)
# This wallet needs Sepolia ETH for gas
PRIVATE_KEY=your_private_key_here

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Sepolia testnet — get a free key at infura.io or alchemy.com
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# ── Etherscan ─────────────────────────────────────────────────────────────────
# For verifying contracts after deploy — get at etherscan.io
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Contract parameters ───────────────────────────────────────────────────────
# Initial CDI rate in basis points (e.g. 1365 = 13.65% p.a.)
INITIAL_CDI_RATE=1365
TOKEN_NAME=Rendex Token
TOKEN_SYMBOL=RDX
INITIAL_SUPPLY=1000000

# ── Oracle service wallet ─────────────────────────────────────────────────────
# Address of the wallet that will call updateCDI() daily (can be same as deployer for now)
# If set, it will be authorized as an updater during deploy
ORACLE_UPDATER_ADDRESS=0x...

# ── Filled after deploy ───────────────────────────────────────────────────────
# Copy these from deployments/sepolia.json after running deploy:sepolia
CDI_ORACLE_ADDRESS=0x...
RENDEX_TOKEN_ADDRESS=0x...

# ── Optional: gas reporting ───────────────────────────────────────────────────
# REPORT_GAS=true
# COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
